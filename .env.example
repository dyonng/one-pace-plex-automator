# One Pace RSS feed URL
RSS_FEED_URL=https://onepace.net/en/releases/rss.xml

# qBittorrent (use container name if on same Docker network)
QBIT_URL=http://qbittorrent:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=changeme
# Category applied to added torrents, also used to filter on completion (default: one-pace)
QBIT_CATEGORY=one-pace

# Plex Media Server (use host IP if Plex runs on baremetal)
PLEX_URL=http://192.168.x.x:32400
PLEX_TOKEN=your-plex-token-here
# Name of the Plex library containing One Pace (default: TV Shows)
PLEX_LIBRARY_NAME=TV Shows

# Discord webhook for notifications (optional)
DISCORD_WEBHOOK_URL=

# Cron schedule for RSS polling (default: every 5 minutes)
POLL_CRON=*/5 * * * *

# Log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info

# One Pace metadata dataset base URL (default: ladyisatis/one-pace-metadata v2)
# Override only if mirroring the dataset elsewhere.
METADATA_REPO_RAW_BASE=https://raw.githubusercontent.com/ladyisatis/one-pace-metadata/v2
