# Timezone for cron schedules (default UTC). e.g. America/Toronto, Europe/London
TZ=UTC

# One Pace RSS feed URL
RSS_FEED_URL=https://onepace.net/en/releases/rss.xml

# qBittorrent (use container name if on same Docker network)
QBIT_URL=http://qbittorrent:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=changeme
# Category applied to added torrents, also used to filter on completion (default: one-pace)
QBIT_CATEGORY=one-pace

# Plex Media Server (use host IP if Plex runs on baremetal)
PLEX_URL=http://192.168.x.x:32400
PLEX_TOKEN=your-plex-token-here
# Name of the Plex library containing One Pace (default: TV Shows)
PLEX_LIBRARY_NAME=TV Shows

# Discord webhook for notifications (optional)
DISCORD_WEBHOOK_URL=

# Cron schedule for RSS polling (default: every 5 minutes).
# This and a few others (download-check interval, Discord webhook, RSS URL) are
# also editable live from the dashboard — a dashboard override wins over this.
POLL_CRON=*/5 * * * *

# How often to check qBittorrent for completed downloads, in seconds (default 30).
DOWNLOAD_CHECK_SECONDS=30

# Auto-download discovered releases (default true). Set false to require a manual
# Download click in the dashboard. Also toggleable live from the dashboard.
AUTO_DOWNLOAD=true

# Auto-apply a season's poster when a brand-new season first appears (default true).
# Existing seasons are left as-is, so manually set posters are preserved.
AUTO_POSTERS=true

# Fan-made season/show posters, courtesy of SpykerNZ/one-pace-for-plex:
#   https://github.com/SpykerNZ/one-pace-for-plex
# Override only to use a different poster source.
POSTER_REPO_RAW_BASE=https://raw.githubusercontent.com/SpykerNZ/one-pace-for-plex/main/One%20Pace

# Log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info

# Dashboard (port 8282).
# Easiest: leave the secrets below unset and set a password directly in the
# dashboard UI (Authentication section) — it hashes and stores it for you. On
# first run with no password the dashboard starts OPEN (warned in logs) until you
# set one. Login is HTTP Basic auth (sent base64, not encrypted) — use a TLS
# reverse proxy if exposing beyond your LAN.
#
# Optional bootstrap secret (so it's protected before you open the UI):
#   npm run hash-token -- <your-password>   # prints the line below
# DASHBOARD_TOKEN_HASH=scrypt$<salt>$<hash>
# DASHBOARD_TOKEN=plaintext-fallback        # used only if no hash is set
DASHBOARD_PORT=8282

# One Pace metadata dataset base URL (default: ladyisatis/one-pace-metadata v2)
# Override only if mirroring the dataset elsewhere.
METADATA_REPO_RAW_BASE=https://raw.githubusercontent.com/ladyisatis/one-pace-metadata/v2
