# One Pace RSS feed URL
RSS_FEED_URL=https://onepace.net/en/releases/rss.xml

# qBittorrent (use container name if on same Docker network)
QBIT_URL=http://qbittorrent:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=changeme
QBIT_CATEGORY=one-pace
QBIT_DOWNLOAD_PATH=/downloads/one-pace

# Plex Media Server
PLEX_URL=http://plex:32400
PLEX_TOKEN=your-plex-token-here
# Library section ID — find it at: http://plex:32400/library/sections (look for "key" value)
PLEX_LIBRARY_SECTION_ID=1
# Optional: rating key of the One Pace series entry (speeds up episode lookups)
# Find it by browsing to the show in Plex and checking the URL or API
PLEX_SERIES_RATING_KEY=

# Media library paths (must match your actual host paths)
MEDIA_PATH=/media/tv
SERIES_FOLDER_NAME=One Pace

# Discord webhook for notifications (optional)
DISCORD_WEBHOOK_URL=

# Docker network name shared with your arr stack
DOCKER_NETWORK=media-stack

# Polling interval in minutes (minimum 5)
POLL_INTERVAL_MINUTES=60

# Log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info
