{
  "name": "one-pace-plex-automator",
  "version": "0.1.36",
  "private": true,
  "description": "Automates One Pace fan-edit downloads, renaming, and Plex metadata management",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "ts-node src/index.ts | pino-pretty",
    "dev:web": "vite",
    "mock": "node scripts/mock-server.mjs",
    "hash-token": "node scripts/hash-token.mjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "install:dev": "npm install --ignore-scripts",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "better-sqlite3": "^11.3.0",
    "node-cron": "^3.0.3",
    "pino": "^10.3.1",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@fontsource/chakra-petch": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/node-cron": "^3.0.11",
    "cronstrue": "^3.14.0",
    "daisyui": "^5.5.20",
    "pino-pretty": "^13.1.3",
    "svelte": "^5.56.2",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vite": "^6.4.3"
  }
}
