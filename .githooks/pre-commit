#!/bin/sh
# Bump the patch version on every commit that touches the software itself.
# Docs-only commits (markdown, CI config, hooks) skip the bump so they don't
# produce a new "version" with identical behavior.
if git diff --cached --name-only | grep -qvE '(\.md$|^docs/|^\.github/|^\.githooks/)'; then
  node -e "
  const fs = require('fs');
  const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
  const [maj, min, pat] = pkg.version.split('.').map(Number);
  const next = maj + '.' + min + '.' + (pat + 1);
  pkg.version = next;
  fs.writeFileSync('package.json', JSON.stringify(pkg, null, 2) + '\n');
  // Keep package-lock.json's version fields in step so the two never drift.
  try {
    const lock = JSON.parse(fs.readFileSync('package-lock.json', 'utf8'));
    lock.version = next;
    if (lock.packages && lock.packages['']) lock.packages[''].version = next;
    fs.writeFileSync('package-lock.json', JSON.stringify(lock, null, 2) + '\n');
  } catch (e) { /* no lockfile — fine */ }
  process.stdout.write('version bumped to ' + next + '\n');
  "
  git add package.json package-lock.json
else
  echo "docs-only commit — skipping version bump"
fi
